    {
      "parameters": {
        "jsCode": "const update = $input.first().json;\nconst message = update.body.message || update.body.edited_message;\n\nif (!message) {\n  return [{ json: { skip: true, reason: 'no_message' } }];\n}\n\nconst chatId = message.chat.id;\nconst telegramId = message.from.id;\nconst firstName = message.from.first_name || '';\nconst lastName = message.from.last_name || '';\nconst username = message.from.username || '';\nconst text = message.text || '';\nconst messageType = message.photo ? 'photo'\n  : message.voice ? 'voice'\n  : message.document ? 'document'\n  : message.location ? 'location'\n  : 'text';\nconst messageId = message.message_id;\nconst date = new Date(message.date * 1000).toISOString();\n\nreturn [{\n  json: {\n    skip: false,\n    chatId,\n    telegramId,\n    firstName,\n    lastName,\n    username,\n    text,\n    messageType,\n    messageId,\n    date\n  }\n}];"
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
      "name": "Extract Telegram Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
