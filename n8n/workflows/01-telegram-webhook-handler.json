    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT u.id AS user_id, u.telegram_id, u.first_name, u.is_active,\n       m.plan_type, m.status AS membership_status, m.expires_at\nFROM users u\nLEFT JOIN memberships m ON u.id = m.user_id\n  AND m.status = 'active'\n  AND m.expires_at > NOW()\nWHERE u.telegram_id = $1\nORDER BY m.expires_at DESC\nLIMIT 1;",
        "additionalFields": {
          "queryParams": "={{ [$('Extract Telegram Data').item.json.telegramId] }}"
        }
      },
