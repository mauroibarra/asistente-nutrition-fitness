    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO conversation_logs (user_id, message_text, response_text, message_type, tokens_used, tools_called, processing_ms)\nVALUES ($1, $2, $3, $4, $5, $6, $7);",
        "additionalFields": {
          "queryParams": "={{ [\n  $('Build Context').item.json.userId,\n  $('Build Context').item.json.text,\n  $('AI Agent').item.json.output,\n  'text',\n  0,\n  '[]',\n  0\n] }}"
        }
      },
