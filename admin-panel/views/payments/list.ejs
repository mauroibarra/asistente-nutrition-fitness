<%- include('../_header', { pageTitle: 'Pagos' }) %>

<div class="page-header">
  <h1 class="page-title">Pagos</h1>
</div>

<section class="card card-form">
  <h2>Registrar Nuevo Pago</h2>
  <form method="POST" action="/payments">
    <div class="form-row">
      <div class="form-group form-group-grow">
        <label for="user_id">Usuario *</label>
        <select id="user_id" name="user_id" required>
          <option value="">Seleccionar usuario...</option>
          <% users.forEach(function(u) { %>
            <option value="<%= u.id %>">
              <%= u.first_name %> <%= u.last_name || '' %> (<%= u.telegram_id %>)<% if (u.plan_type) { %> — <%= u.plan_type %><% } %>
            </option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label for="amount">Monto *</label>
        <input type="number" id="amount" name="amount" step="0.01" min="1" required placeholder="799.00">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="payment_method">Metodo *</label>
        <select id="payment_method" name="payment_method" required>
          <option value="transfer">Transferencia</option>
          <option value="cash">Efectivo</option>
          <option value="card">Tarjeta</option>
          <option value="other">Otro</option>
        </select>
      </div>
      <div class="form-group">
        <label for="payment_date">Fecha *</label>
        <input type="date" id="payment_date" name="payment_date" required value="<%= new Date().toISOString().split('T')[0] %>">
      </div>
    </div>
    <div class="form-group">
      <label for="reference_note">Referencia / Nota</label>
      <input type="text" id="reference_note" name="reference_note" placeholder="Transferencia BBVA ref 12345">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Registrar Pago</button>
    </div>
  </form>
</section>

<% if (payments.length === 0) { %>
  <div class="empty-state">Sin pagos registrados.</div>
<% } else { %>
<section class="section">
  <h2>Historial de Pagos</h2>
  <table class="table">
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Usuario</th>
        <th>Monto</th>
        <th>Metodo</th>
        <th>Referencia</th>
        <th>Registrado por</th>
      </tr>
    </thead>
    <tbody>
      <% payments.forEach(function(p) { %>
      <tr>
        <td><%= new Date(p.payment_date).toLocaleDateString('es-MX') %></td>
        <td><%= p.first_name %> <%= p.last_name || '' %></td>
        <td>$<%= parseFloat(p.amount).toLocaleString('es-MX', { minimumFractionDigits: 2 }) %></td>
        <td><%= p.payment_method %></td>
        <td><%= p.reference_note || '—' %></td>
        <td><%= p.registered_by_name || '—' %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>

  <div class="pagination">
    <span>Pagina <%= pagination.page %> de <%= pagination.totalPages %> (<%= pagination.totalPayments %> pagos)</span>
    <% if (pagination.page > 1) { %>
      <a href="?page=<%= pagination.page - 1 %>" class="btn btn-sm btn-secondary">&laquo; Anterior</a>
    <% } %>
    <% if (pagination.page < pagination.totalPages) { %>
      <a href="?page=<%= pagination.page + 1 %>" class="btn btn-sm btn-secondary">Siguiente &raquo;</a>
    <% } %>
  </div>
</section>
<% } %>

<%- include('../_footer') %>
