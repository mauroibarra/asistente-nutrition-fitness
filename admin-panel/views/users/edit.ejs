<%- include('../_header', { pageTitle: 'Editar: ' + user.first_name }) %>

<div class="page-header">
  <a href="/users/<%= user.id %>" class="btn btn-link">&larr; Volver</a>
  <h1 class="page-title">Editar Usuario</h1>
</div>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>
<% if (typeof query !== 'undefined' && query.delete_error) { %>
  <div class="alert alert-error">El nombre ingresado no coincide. Eliminación cancelada.</div>
<% } %>

<!-- ── Datos del usuario ──────────────────────────────────── -->
<section class="card card-form">
  <h2>Datos del Usuario</h2>
  <form method="POST" action="/users/<%= user.id %>/update">

    <div class="form-group">
      <label for="telegram_id">Telegram ID *</label>
      <input type="number" id="telegram_id" name="telegram_id" required
             value="<%= user.telegram_id %>">
      <small>Cambiar solo si el usuario creó una cuenta nueva en Telegram.</small>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="first_name">Nombre *</label>
        <input type="text" id="first_name" name="first_name" required
               value="<%= user.first_name %>">
      </div>
      <div class="form-group">
        <label for="last_name">Apellido</label>
        <input type="text" id="last_name" name="last_name"
               value="<%= user.last_name || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="document_number">Nro. de Documento</label>
        <input type="text" id="document_number" name="document_number"
               placeholder="CC, DNI, Pasaporte..."
               value="<%= user.document_number || '' %>">
      </div>
      <div class="form-group">
        <label for="phone_number">Celular</label>
        <input type="tel" id="phone_number" name="phone_number"
               placeholder="+57 300 123 4567"
               value="<%= user.phone_number || '' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="country">País</label>
        <input type="text" id="country" name="country"
               placeholder="Colombia"
               value="<%= user.country || '' %>">
      </div>
      <div class="form-group">
        <label for="city">Ciudad</label>
        <input type="text" id="city" name="city"
               placeholder="Bogotá"
               value="<%= user.city || '' %>">
      </div>
    </div>

    <div class="form-actions">
      <a href="/users/<%= user.id %>" class="btn btn-secondary">Cancelar</a>
      <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    </div>
  </form>
</section>

<!-- ── Zona de peligro ───────────────────────────────────── -->
<section class="card danger-zone">
  <h2>Zona de Peligro</h2>
  <p>
    Eliminar un usuario borra <strong>permanentemente</strong> su perfil de salud, historial de peso,
    planes de comidas, rutinas, membresías y pagos. Esta acción <strong>no se puede deshacer</strong>.
  </p>

  <button type="button" class="btn btn-danger"
          onclick="document.getElementById('delete-section').style.display='block';this.style.display='none'">
    Eliminar este usuario
  </button>

  <div id="delete-section" style="display:none;margin-top:1.25rem">
    <div class="delete-confirm-box">
      <p>Para confirmar, escribe el nombre completo del usuario:
        <strong><%= user.first_name %><%= user.last_name ? ' ' + user.last_name : '' %></strong>
      </p>
      <form method="POST" action="/users/<%= user.id %>/delete">
        <div class="form-group">
          <input type="text" name="confirm_name" required
                 placeholder="<%= user.first_name %><%= user.last_name ? ' ' + user.last_name : '' %>"
                 autocomplete="off">
        </div>
        <div class="form-actions" style="justify-content:flex-start">
          <button type="button" class="btn btn-secondary"
                  onclick="document.getElementById('delete-section').style.display='none';
                           document.querySelector('.btn-danger').style.display='inline-block'">
            Cancelar
          </button>
          <button type="submit" class="btn btn-danger-solid">
            Eliminar permanentemente
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../_footer') %>
