<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FitAI Admin — Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
<div class="login-container">
  <h1>FitAI Assistant</h1>
  <h2>Panel de Administracion</h2>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/login">
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required placeholder="admin@fitai.com" autofocus>
    </div>
    <div class="form-group">
      <label for="password">Contrasena</label>
      <input type="password" id="password" name="password" required placeholder="••••••••">
    </div>
    <button type="submit" class="btn btn-primary btn-full">Iniciar Sesion</button>
  </form>
</div>
</body>
</html>
