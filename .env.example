# ============================================================
# FitAI Assistant — Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el archivo .env al repositorio.
# ============================================================

# ------------------------------------------------------------
# OpenAI — LLM en producción (GPT-4o) y embeddings
# ------------------------------------------------------------
# API key de OpenAI. Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Telegram — Canal de comunicación con usuarios
# ------------------------------------------------------------
# Token del bot. Obtener de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Secret para verificar la autenticidad de webhooks entrantes
TELEGRAM_WEBHOOK_SECRET=un-secret-aleatorio-seguro

# ------------------------------------------------------------
# PostgreSQL — Base de datos principal
# ------------------------------------------------------------
# Credenciales para Docker (usadas por el contenedor de PostgreSQL)
POSTGRES_USER=fitai
POSTGRES_PASSWORD=una-contraseña-segura
POSTGRES_DB=fitai_db

# URL de conexión completa (usada por n8n y el panel admin)
# Formato: postgresql://usuario:contraseña@host:puerto/base_de_datos
DATABASE_URL=postgresql://fitai:una-contraseña-segura@postgres:5432/fitai_db

# ------------------------------------------------------------
# Redis — Caché y estado efímero
# ------------------------------------------------------------
# URL de conexión a Redis
# Formato: redis://host:puerto
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Qdrant — Vector store para RAG
# ------------------------------------------------------------
# URL de la instancia de Qdrant
QDRANT_URL=http://qdrant:6333

# API key de Qdrant (opcional, solo si se configura autenticación)
QDRANT_API_KEY=

# ------------------------------------------------------------
# n8n — Orquestación de workflows
# ------------------------------------------------------------
# URL base de n8n (interna en Docker o externa en producción)
N8N_BASE_URL=http://localhost:5678/

# API key para acceso programático a n8n (generar en n8n: Settings > API)
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI4MTllOGUzMC04YzIyLTQ1ZjUtYmZjNC1hMGMxNWI0MDZkZWEiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwianRpIjoiMWE3ZTgyNWUtNzY0YS00OWUzLTg1MWItYTFmYTA2NjEwMzM1IiwiaWF0IjoxNzc0NjI3MDQ4fQ.WGYsW4bZGPWxBB01IduEuRpG5qRc7d3_Dh-0T6wLagI

# Clave para encriptar credenciales almacenadas en n8n
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=clave-de-encriptacion-hex-de-64-caracteres

# Usuario y contraseña para el primer acceso a n8n
N8N_BASIC_AUTH_USER=leandro.147.mi@gmail.com
N8N_BASIC_AUTH_PASSWORD=leandrO_023

# ------------------------------------------------------------
# Panel de Administración — Gestión de usuarios y membresías
# ------------------------------------------------------------
# Puerto en el que corre el panel admin (default: 3000)
ADMIN_PANEL_PORT=3000

# Secret para firmar las cookies de sesión del panel admin
# Generar con: openssl rand -hex 32
ADMIN_PANEL_SECRET_KEY=secret-de-sesion-hex-de-64-caracteres

# ------------------------------------------------------------
# Configuración General
# ------------------------------------------------------------
# Entorno de ejecución: development | production
NODE_ENV=development

# Nivel de logging: debug | info | warn | error
LOG_LEVEL=info

# ------------------------------------------------------------
# Dominio (solo producción)
# ------------------------------------------------------------
# Dominio donde se desplegará el sistema
# DOMAIN=fitai.tudominio.com
